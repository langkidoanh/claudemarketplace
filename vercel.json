{
  "version": 2,
  "name": "claudemarketplace",
  "outputDirectory": "frontend",
  "routes": [
    { "src": "/ai-agents",                "dest": "/marketplace.html" },
    { "src": "/ai-agents/([^/]+)",        "dest": "/agent-detail.html" },
    { "src": "/marketplace",              "dest": "/marketplace.html" },
    { "src": "/tin-tuc-ai-agents",        "dest": "/news.html" },
    { "src": "/tin-tuc-([^/]+)",          "dest": "/news.html" },
    { "src": "/tin-tuc-([^/]+)/([^/]+)",  "dest": "/news-detail.html" },
    { "src": "/news",                     "dest": "/news.html" },
    { "src": "/news-detail",              "dest": "/news-detail.html" },
    { "src": "/dich-vu",                  "dest": "/services.html" },
    { "src": "/dich-vu/([^/]+)",          "dest": "/services.html" },
    { "src": "/services",                 "dest": "/services.html" },
    { "src": "/lien-he",                  "dest": "/contact.html" },
    { "src": "/ve-chung-toi",             "dest": "/contact.html" },
    { "src": "/contact",                  "dest": "/contact.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)",                     "dest": "/index.html" }
  ]
}
