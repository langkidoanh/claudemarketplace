{
  "version": 2,
  "name": "claudemarketplace",
  "routes": [
    { "src": "^/css/(.*)",               "dest": "/frontend/css/$1" },
    { "src": "^/js/(.*)",                "dest": "/frontend/js/$1" },
    { "src": "^/assets/(.*)",            "dest": "/frontend/assets/$1" },
    { "src": "^/images/(.*)",            "dest": "/frontend/images/$1" },
    { "src": "^/ai-agents/([^/]+)$",     "dest": "/frontend/agent-detail.html" },
    { "src": "^/ai-agents$",             "dest": "/frontend/marketplace.html" },
    { "src": "^/tin-tuc-([^/]+)/([^/]+)$","dest": "/frontend/news-detail.html" },
    { "src": "^/tin-tuc(.*)$",           "dest": "/frontend/news.html" },
    { "src": "^/dich-vu(.*)$",           "dest": "/frontend/services.html" },
    { "src": "^/lien-he$",              "dest": "/frontend/contact.html" },
    { "src": "^/ve-chung-toi$",          "dest": "/frontend/contact.html" },
    { "src": "^/$",                      "dest": "/frontend/index.html" },
    { "src": "^/(.*)",                   "dest": "/frontend/index.html" }
  ]
}
