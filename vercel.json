{
  "version": 2,
  "name": "claudemarketplace",
  "buildCommand": "mkdir -p public && cp -r frontend/. public/",
  "outputDirectory": "public",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/ai-agents/:slug", "destination": "/agent-detail" },
    { "source": "/tin-tuc-:category/:slug", "destination": "/news-detail" }
  ]
}
