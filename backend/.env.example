# ─── SERVER ──────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── DATABASE (MongoDB - future) ─────────────────
# MONGODB_URI=mongodb://localhost:27017/claudemarketplace

# ─── EMAIL (Nodemailer) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@claudemarketplace.vn
EMAIL_TO=support@claudemarketplace.vn

# ─── RATE LIMITING ───────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── JWT (future auth) ───────────────────────────
# JWT_SECRET=your-super-secret-key
# JWT_EXPIRES_IN=7d

# ─── ANALYTICS ───────────────────────────────────
# GA_TRACKING_ID=UA-XXXXXXXXX-X
